{
  "name": "rayong-trail-live",
  "version": "1.0.0",
  "description": "Rayong Trail Running GPS live tracker — web app + Capacitor native shell for background GPS tracking on iOS/Android.",
  "private": true,
  "scripts": {
    "build:native": "esbuild src/native/gps-tracker.js --bundle --format=iife --global-name=trtGpsTracker --outfile=src/native/gps-tracker.bundle.js",
    "prepare:www": "node scripts/prepare-www.js",
    "cap:sync": "npm run build:native && npm run prepare:www && cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/ios": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "esbuild": "^0.24.0"
  }
}
